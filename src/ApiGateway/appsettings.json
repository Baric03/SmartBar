{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "order-swagger-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api-docs/order"
        },
        "Transforms": [
          {
            "PathSet": "/swagger/v1/swagger.json"
          }
        ]
      },
      "inventory-swagger-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api-docs/inventory"
        },
        "Transforms": [
          {
            "PathSet": "/swagger/v1/swagger.json"
          }
        ]
      },
      "bar-swagger-route": {
        "ClusterId": "bar-cluster",
        "Match": {
          "Path": "/api-docs/bar"
        },
        "Transforms": [
          {
            "PathSet": "/swagger/v1/swagger.json"
          }
        ]
      },
      "notification-swagger-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api-docs/notification"
        },
        "Transforms": [
          {
            "PathSet": "/swagger/v1/swagger.json"
          }
        ]
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/Orders/{**catch-all}"
        }
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/Inventory/{**catch-all}"
        }
      },
      "bar-route": {
        "ClusterId": "bar-cluster",
        "Match": {
          "Path": "/api/Bar/{**catch-all}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/Notification/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "order-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://smartbar-order-service:8080/"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://smartbar-inventory-service:8080/"
          }
        }
      },
      "bar-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://smartbar-bar-service:8080/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://smartbar-notification-service:8080/"
          }
        }
      }
    }
  }
}